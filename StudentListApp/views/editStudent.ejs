<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Edit Student</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Student List App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addStudent">Add new student</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  <div class="container">
    <br>
    <div class="text-center"><h2>Edit Student</h2></div>
    <br>

    <% if (student) { %>

      <form action="/editStudent/<%= student.studentId %>" method="POST" class="mx-auto" style="max-width: 500px;">
        <div class="mb-3">
          <label for="name" class="form-label">Student Name</label>
          <input type="text" class="form-control" id="name" name="name" value="<%= student.name %>" required>
        </div>
        <div class="mb-3">
          <label for="dob" class="form-label">D.o.B</label>
          <input type="date" class="form-control" id="dob" name="dob"
            value="<%= new Date(student.dob).toISOString().split('T')[0] %>" required>
        </div>
        <div class="mb-3">
          <label for="contact" class="form-label">Contact</label>
          <input type="text" class="form-control" id="contact" name="contact" maxlength="10" value="<%= student.contact %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Current Image</label>
          <div class="text-center">
            <img src="<%= student.image %>" alt="<%= student.name %>" width="120">
          </div>
        </div>
        <button type="submit" class="btn btn-warning">Update Student</button>
        <a href="/" class="btn btn-secondary">Cancel</a>
      </form>

    <% } else { %>

      <div class="alert alert-warning text-center">
        <h5>No student found.</h5>
        <a href="/" class="btn btn-secondary mt-3">Back to Home</a>
      </div>

    <% } %>

  </div>
</body>
</html>