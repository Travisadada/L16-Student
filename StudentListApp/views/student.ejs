<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Student Details</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Student List App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addStudent">Add new student</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  <div class="container">
    <br>
    <div class="text-center"><h2>Student Details</h2></div>
    <br>

    <% if (student) { %>
      <div class="card mx-auto" style="max-width: 400px;">
        <img src="<%= student.image %>" class="card-img-top" alt="<%= student.name %>">
        <div class="card-body text-center">
          <h4 class="card-title"><%= student.name %></h4>
          <p class="card-text">Date of Birth: <%= new Date(student.dob).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) %></p>
          <p class="card-text">Contact: <%= student.contact %></p>
          <a href="/" class="btn btn-secondary">Back to Students</a>
        </div>
      </div>
    <% } else { %>
      <p class="text-center">No student found.</p>
    <% } %>
  </div>
</body>
</html>
